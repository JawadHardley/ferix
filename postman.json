  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-refresh token if older than 24 hours",
          "var tokenAge = new Date().getTime() - parseInt(pm.environment.get('token_created_at') || 0);",
          "var tokenExpiry = 24 * 60 * 60 * 1000; // 24 hours in milliseconds",
          "",
          "if (tokenAge > tokenExpiry) {",
          "    console.log('Token expired. Refreshing...');",
          "    pm.sendRequest({",
          "        url: pm.environment.get('base_url') + '/api/login',",
          "        method: 'POST',",
          "        header: {'Content-Type': 'application/json'},",
          "        body: {",
          "            mode: 'raw',",
          "            raw: JSON.stringify({",
          "                email: 'olomidereck@hotmail.com',",
          "                password: '123456'",
          "            })",
          "        }",
          "    }, function(err, response) {",
          "        if (!err) {",
          "            var jsonData = response.json();",
          "            pm.environment.set('api_token', jsonData.token);",
          "            pm.environment.set('token_created_at', new Date().getTime());",
          "            console.log('Token refreshed successfully');",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ],
